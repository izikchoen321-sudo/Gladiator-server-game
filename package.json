const { Player, Battle } = require(’../models’);

const SKILLS_DATA = [
{ id:‘power_strike’,  name:‘מכה עוצמתית’, icon:‘💥’, desc:‘מכה ב-200% נזק’,           cooldown:3, mpCost:20, effect:‘damage_multiplier’, value:2.0 },
{ id:‘shield_bash’,   name:‘הכאת מגן’,    icon:‘🛡️’, desc:‘מדלג על תור יריב’,         cooldown:4, mpCost:25, effect:‘stun’,             value:0.5 },
{ id:‘battle_cry’,    name:‘זעקת קרב’,    icon:‘📣’, desc:’+50% תקיפה לתור הבא’,      cooldown:4, mpCost:15, effect:‘buff_attack’,      value:0.5 },
{ id:‘second_wind’,   name:‘רוח שנייה’,   icon:‘💨’, desc:‘מחזיר 30% HP’,             cooldown:5, mpCost:30, effect:‘heal’,             value:0.3 },
{ id:‘precise_strike’,name:‘מכה מדויקת’, icon:‘🎯’, desc:‘100% קריטי’,               cooldown:3, mpCost:20, effect:‘guaranteed_crit’,  value:1.0 },
{ id:‘arena_roar’,    name:‘שאגת הזירה’,  icon:‘🦁’, desc:’-30% הגנת יריב לתור’,      cooldown:3, mpCost:18, effect:‘debuff_defense’,   value:0.3 },
];

const queue = [];         // matchmaking queue: [{socketId, playerId, username}]
const activeGames = {};   // gameId -> gameState

function calcStats(base, weapon, armor, talents = []) {
let s = { …base };
if (weapon?.bonus) Object.entries(weapon.bonus).forEach(([k, v]) => s[k] = (s[k] || 0) + v);
if (armor?.bonus)  Object.entries(armor.bonus).forEach(([k, v]) => s[k] = (s[k] || 0) + v);
return s;
}

function doCombatTurn(attacker, defender, skillId) {
const logs = [];
let dmg = Math.max(1, attacker.attack - defender.defense + Math.floor(Math.random() * 8) - 3);
let stunned = false, extraHeal = 0, buffAttack = false, defenseDebuff = 0;

if (skillId) {
const skill = SKILLS_DATA.find(s => s.id === skillId);
if (skill) {
if (skill.effect === ‘damage_multiplier’) dmg = Math.floor(dmg * skill.value);
if (skill.effect === ‘stun’)              { stunned = true; dmg = Math.floor(dmg * 0.5); }
if (skill.effect === ‘buff_attack’)       buffAttack = true;
if (skill.effect === ‘heal’)              extraHeal = Math.floor(attacker.maxHp * skill.value);
if (skill.effect === ‘guaranteed_crit’)   dmg = Math.floor(dmg * 2.0);
if (skill.effect === ‘debuff_defense’)    defenseDebuff = Math.floor(defender.defense * skill.value);
logs.push(`${skill.icon} ${skill.name}`);
}
}

const isCrit = !skillId && Math.random() * 100 < (attacker.critChance || 10);
if (isCrit) { dmg = Math.floor(dmg * 2); logs.push(‘💥 קריטי!’); }

const dodge = defender.dodge || 0;
if (Math.random() < dodge) { dmg = 0; logs.push(‘💨 חמקה!’); }

return { dmg, stunned, extraHeal, buffAttack, logs, defenseDebuff };
}

function setupGameSockets(io) {
// Track socketId -> playerId
const socketToPlayer = {};

io.on(‘connection’, (socket) => {
console.log(`🔌 Socket connected: ${socket.id}`);

```
// Authenticate
socket.on('auth', async ({ token }) => {
  try {
    const jwt = require('jsonwebtoken');
    const SECRET = process.env.JWT_SECRET || 'gladiator_secret_change_me';
    const decoded = jwt.verify(token, SECRET);
    const player = await Player.findById(decoded.id).select('-password');
    if (!player || player.isBanned) {
      socket.emit('auth_error', { error: 'Authentication failed' });
      return;
    }
    socketToPlayer[socket.id] = player._id.toString();
    socket.playerId = player._id.toString();
    socket.username = player.username;
    socket.emit('auth_ok', { username: player.username, isAdmin: player.isAdmin });
    console.log(`✅ Authed: ${player.username}`);
  } catch (err) {
    socket.emit('auth_error', { error: 'Invalid token' });
  }
});

// Matchmaking
socket.on('find_match', async () => {
  if (!socket.playerId) return socket.emit('error', { msg: 'Not authenticated' });

  // Remove if already in queue
  const idx = queue.findIndex(q => q.playerId === socket.playerId);
  if (idx !== -1) queue.splice(idx, 1);

  const player = await Player.findById(socket.playerId);
  if (!player) return;

  // Check not already in game
  const inGame = Object.values(activeGames).find(g =>
    g.players[0].id === socket.playerId || g.players[1].id === socket.playerId
  );
  if (inGame) {
    socket.emit('match_found', { gameId: inGame.id });
    return;
  }

  queue.push({ socketId: socket.id, playerId: socket.playerId, username: player.username, rank: player.rank });
  socket.emit('in_queue', { position: queue.length });

  // Try to match
  if (queue.length >= 2) {
    const p1 = queue.shift();
    const p2 = queue.shift();
    const gameId = `game_${Date.now()}`;

    const [player1, player2] = await Promise.all([
      Player.findById(p1.playerId),
      Player.findById(p2.playerId),
    ]);

    const buildFighter = (p) => {
      const stats = calcStats(p.gladiator.baseStats, p.gladiator.weapon, p.gladiator.armor, p.gladiator.talents);
      return {
        id: p._id.toString(),
        username: p.username,
        icon: p.gladiator.icon,
        level: p.gladiator.level,
        ...stats,
        maxHp: stats.hp,
        currentHp: stats.hp,
        mp: 80, maxMp: 80,
        equippedSkills: p.gladiator.equippedSkills || [],
        skillCooldowns: {},
        buffActive: false,
      };
    };

    const game = {
      id: gameId,
      players: [buildFighter(player1), buildFighter(player2)],
      sockets: [p1.socketId, p2.socketId],
      turn: 0,            // 0 = player1's turn, 1 = player2's turn
      turnNumber: 1,
      log: [],
      over: false,
      startedAt: new Date(),
    };
    activeGames[gameId] = game;

    const s1 = io.sockets.sockets.get(p1.socketId);
    const s2 = io.sockets.sockets.get(p2.socketId);
    [s1, s2].forEach((s, i) => {
      if (s) {
        s.join(gameId);
        s.gameId = gameId;
        s.playerIndex = i;
        s.emit('match_found', {
          gameId,
          yourIndex: i,
          players: game.players.map(p => ({ username: p.username, icon: p.icon, level: p.level, maxHp: p.maxHp })),
        });
      }
    });

    io.to(gameId).emit('game_state', safeState(game));
    io.to(gameId).emit('game_log', [`⚔️ הקרב מתחיל! ${game.players[0].username} VS ${game.players[1].username}`, `🎯 תור של ${game.players[0].username}`]);
  }
});

// Cancel queue
socket.on('cancel_queue', () => {
  const idx = queue.findIndex(q => q.playerId === socket.playerId);
  if (idx !== -1) queue.splice(idx, 1);
  socket.emit('queue_cancelled');
});

// Combat action
socket.on('combat_action', async ({ gameId, action, skillId }) => {
  const game = activeGames[gameId];
  if (!game || game.over) return;

  const playerIndex = game.sockets.indexOf(socket.id);
  if (playerIndex === -1 || game.turn !== playerIndex) {
    socket.emit('not_your_turn');
    return;
  }

  const attacker = game.players[playerIndex];
  const defender = game.players[1 - playerIndex];
  const logs = [`--- תור ${game.turnNumber} ---`];

  if (action === 'attack') {
    // Validate skill
    let usedSkill = null;
    if (skillId) {
      const skill = SKILLS_DATA.find(s => s.id === skillId);
      if (skill && attacker.equippedSkills.includes(skillId)) {
        const cd = attacker.skillCooldowns[skillId] || 0;
        if (cd > 0) { socket.emit('skill_on_cooldown', { skillId, cd }); return; }
        if (attacker.mp < skill.mpCost) { socket.emit('not_enough_mp'); return; }
        attacker.mp -= skill.mpCost;
        usedSkill = skill;
      }
    }

    const result = doCombatTurn(
      { ...attacker, maxHp: attacker.maxHp },
      { ...defender, defense: defender.defense },
      usedSkill?.id || null
    );

    defender.currentHp = Math.max(0, defender.currentHp - result.dmg);
    attacker.currentHp = Math.min(attacker.maxHp, attacker.currentHp + result.extraHeal);
    attacker.mp = Math.min(attacker.maxMp, attacker.mp + 8);

    if (usedSkill) {
      attacker.skillCooldowns[usedSkill.id] = usedSkill.cooldown;
    }
    if (attacker.buffActive) attacker.buffActive = false;
    if (skillId === 'battle_cry') attacker.buffActive = true;

    // Reduce cooldowns
    Object.keys(attacker.skillCooldowns).forEach(k => {
      if (attacker.skillCooldowns[k] > 0) attacker.skillCooldowns[k]--;
    });

    const skillLine = usedSkill ? `${usedSkill.icon} [${usedSkill.name}]` : '';
    logs.push(`🗡️ ${attacker.username} ${skillLine} → ${result.dmg} נזק${result.extraHeal > 0 ? ` + ❤️${result.extraHeal}` : ''}`);
    result.logs.forEach(l => logs.push(l));

    if (result.stunned) {
      logs.push(`😵 ${defender.username} מתעלף!`);
      // Skip defender turn
      game.turn = playerIndex;
      game.turnNumber++;
      game.log.push(...logs);
      if (defender.currentHp <= 0) await endGame(io, game, playerIndex, logs);
      else io.to(gameId).emit('game_state', safeState(game));
      io.to(gameId).emit('game_log', logs);
      return;
    }

    if (defender.currentHp <= 0) {
      await endGame(io, game, playerIndex, logs);
      return;
    }

    game.turn = 1 - playerIndex;
    game.turnNumber++;
    game.log.push(...logs);
    logs.push(`🎯 תור של ${game.players[game.turn].username}`);
    io.to(gameId).emit('game_state', safeState(game));
    io.to(gameId).emit('game_log', logs);

  } else if (action === 'use_potion') {
    const playerDoc = await Player.findById(attacker.id);
    if (!playerDoc.gladiator.potions.length) {
      socket.emit('no_potions');
      return;
    }
    const potion = playerDoc.gladiator.potions.shift();
    await playerDoc.save();
    attacker.currentHp = Math.min(attacker.maxHp, attacker.currentHp + potion.heal);
    logs.push(`🧪 ${attacker.username} השתמש ב${potion.name} → ❤️ +${potion.heal}`);

    game.turn = 1 - playerIndex;
    game.turnNumber++;
    game.log.push(...logs);
    logs.push(`🎯 תור של ${game.players[game.turn].username}`);
    io.to(gameId).emit('game_state', safeState(game));
    io.to(gameId).emit('game_log', logs);
  }
});

// Surrender
socket.on('surrender', async ({ gameId }) => {
  const game = activeGames[gameId];
  if (!game || game.over) return;
  const playerIndex = game.sockets.indexOf(socket.id);
  if (playerIndex === -1) return;
  const winnerId = 1 - playerIndex;
  await endGame(io, game, winnerId, [`🏳️ ${game.players[playerIndex].username} נכנע!`]);
});

// Disconnect
socket.on('disconnect', () => {
  const idx = queue.findIndex(q => q.socketId === socket.id);
  if (idx !== -1) queue.splice(idx, 1);
  console.log(`❌ Disconnected: ${socket.id}`);
});

// Admin: get online count
socket.on('admin_stats', () => {
  if (!socket.playerId) return;
  socket.emit('admin_online', {
    online: Object.keys(socketToPlayer).length,
    inQueue: queue.length,
    activeGames: Object.keys(activeGames).length,
  });
});
```

});

// ── END GAME ───────────────────────────────────
async function endGame(io, game, winnerIndex, extraLogs = []) {
game.over = true;
const winner = game.players[winnerIndex];
const loser  = game.players[1 - winnerIndex];

```
const XP_GAIN_WIN  = 80 + game.turnNumber * 5;
const XP_GAIN_LOSE = 25;
const GOLD_WIN  = 60 + winnerIndex * 10;
const GOLD_LOSE = 20;
const RANK_CHANGE = 25;

const [winnerDoc, loserDoc] = await Promise.all([
  Player.findById(winner.id),
  Player.findById(loser.id),
]);

const addXpAndLevel = (p, xp) => {
  p.gladiator.xp = (p.gladiator.xp || 0) + xp;
  const XP_PER = (lvl) => Math.floor(100 * Math.pow(1.5, lvl - 1));
  let leveled = false;
  while (p.gladiator.xp >= XP_PER(p.gladiator.level)) {
    p.gladiator.xp -= XP_PER(p.gladiator.level);
    p.gladiator.level++;
    p.gladiator.talentPoints = (p.gladiator.talentPoints || 0) + 1;
    p.gladiator.baseStats.hp       += 8;
    p.gladiator.baseStats.attack   += 2;
    p.gladiator.baseStats.defense  += 1;
    leveled = true;
  }
  return leveled;
};

winnerDoc.wins++;
winnerDoc.rank = (winnerDoc.rank || 1000) + RANK_CHANGE;
winnerDoc.gold += GOLD_WIN;
const wLeveled = addXpAndLevel(winnerDoc, XP_GAIN_WIN);
await winnerDoc.save();

loserDoc.losses++;
loserDoc.rank = Math.max(0, (loserDoc.rank || 1000) - RANK_CHANGE);
loserDoc.gold += GOLD_LOSE;
addXpAndLevel(loserDoc, XP_GAIN_LOSE);
await loserDoc.save();

// Save battle
await Battle.create({
  player1: { id: winnerDoc._id, username: winner.username, rank: winnerDoc.rank },
  player2: { id: loserDoc._id,  username: loser.username,  rank: loserDoc.rank },
  winner: winnerDoc._id, loser: loserDoc._id,
  turns: game.turnNumber,
  log: [...game.log, ...extraLogs],
  rankChange: { winner: RANK_CHANGE, loser: -RANK_CHANGE },
});

const endLogs = [
  ...extraLogs,
  `🏆 ${winner.username} ניצח!`,
  `+${XP_GAIN_WIN} XP, +${GOLD_WIN} זהב, +${RANK_CHANGE} דירוג`,
  wLeveled ? `⬆️ ${winner.username} עלה לרמה ${winnerDoc.gladiator.level}!` : null,
].filter(Boolean);

game.log.push(...endLogs);

io.to(game.id).emit('game_over', {
  winnerId: winner.id,
  winnerName: winner.username,
  loserName: loser.username,
  logs: endLogs,
  rewards: {
    winner: { xp: XP_GAIN_WIN, gold: GOLD_WIN, rank: RANK_CHANGE, leveled: wLeveled, newLevel: winnerDoc.gladiator.level },
    loser:  { xp: XP_GAIN_LOSE, gold: GOLD_LOSE, rank: -RANK_CHANGE },
  }
});

delete activeGames[game.id];
```

}
}

function safeState(game) {
return {
id: game.id,
turn: game.turn,
turnNumber: game.turnNumber,
over: game.over,
players: game.players.map(p => ({
id: p.id, username: p.username, icon: p.icon, level: p.level,
currentHp: p.currentHp, maxHp: p.maxHp,
mp: p.mp, maxMp: p.maxMp,
equippedSkills: p.equippedSkills,
skillCooldowns: p.skillCooldowns,
}))
};
}

module.exports = { setupGameSockets };
