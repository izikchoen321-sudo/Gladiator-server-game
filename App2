          {k:'icon', label:'אייקון (emoji)', type:'text'},
          {k:'desc', label:'תיאור', type:'text'},
          {k:'priceGold', label:'מחיר זהב', type:'number'},
          {k:'priceCoins', label:'מחיר מטבעות', type:'number'},
          {k:'realPrice', label:'מחיר $$', type:'number'},
          {k:'tier', label:'רמה', type:'number'},
        ].map(f => (
          <div key={f.k} className="form-row">
