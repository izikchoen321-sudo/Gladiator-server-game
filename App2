export default function AdminPanel() {
const [tab, setTab] = useState(‘dashboard’);
const [stats, setStats] = useState(null);
const [players, setPlayers] = useState([]);
const [playerTotal, setPlayerTotal] = useState(0);
const [shopItems, setShopItems] = useState([]);
const [transactions, setTransactions] = useState([]);
const [search, setSearch] = useState(’’);
const [notif, setNotif] = useState(null);
const [modal, setModal] = useState(null); // {type, data}
const [loading, setLoading] = useState(false);

const notify = (msg, type = ‘success’) => {
setNotif({ msg, type });
setTimeout(() => setNotif(null), 3000);
};

const loadStats = useCallback(async () => {
try { const r = await api.get(’/admin/stats’); setStats(r.data); } catch {}
}, []);

const loadPlayers = useCallback(async (s = ‘’) => {
try {
const r = await api.get(`/admin/players?search=${s}&limit=50`);
setPlayers(r.data.players);
setPlayerTotal(r.data.total);
} catch {}
}, []);

const loadShop = useCallback(async () => {
try { const r = await api.get(’/admin/shop’); setShopItems(r.data); } catch {}
}, []);

const loadTransactions = useCallback(async () => {
try { const r = await api.get(’/admin/transactions’); setTransactions(r.data); } catch {}
}, []);

useEffect(() => { loadStats(); }, []);
useEffect(() => {
if (tab === ‘players’) loadPlayers(search);
if (tab === ‘shop’) loadShop();
if (tab === ‘transactions’) loadTransactions();
}, [tab]);

const banPlayer = async (id, ban, reason = ‘’) => {
try {
const ep = ban ? `/admin/players/${id}/ban` : `/admin/players/${id}/unban`;
const r = await api.post(ep, { reason });
notify(r.data.message);
loadPlayers(search);
} catch (err) { notify(err.response?.data?.error || ‘שגיאה’, ‘error’); }
};

const deletePlayer = async (id) => {
if (!window.confirm(‘בטוח?’)) return;
try { await api.delete(`/admin/players/${id}`); notify(‘שחקן נמחק’); loadPlayers(search); }
catch (err) { notify(err.response?.data?.error || ‘שגיאה’, ‘error’); }
};

const giveCoins = async (id, amount) => {
try { const r = await api.post(`/admin/players/${id}/give-coins`, { coins: amount }); notify(`ניתנו ${amount} מטבעות`); loadPlayers(search); }
catch (err) { notify(err.response?.data?.error || ‘שגיאה’, ‘error’); }
};

const saveShopItem = async (item) => {
setLoading(true);
try {
if (item._id) {
await api.put(`/admin/shop/${item.id}`, item);
} else {
await api.post(’/admin/shop’, item);
}
notify(‘נשמר!’);
setModal(null);
loadShop();
} catch (err) { notify(err.response?.data?.error || ‘שגיאה’, ‘error’); }
setLoading(false);
};

const deleteShopItem = async (id) => {
if (!window.confirm(‘בטוח?’)) return;
try { await api.delete(`/admin/shop/${id}`); notify(‘נמחק’); loadShop(); }
catch {}
};

const seedShop = async () => {
try { const r = await api.post(’/admin/seed-shop’, {}); notify(`Seeded ${r.data.count} פריטים`); loadShop(); }
catch (err) { notify(err.response?.data?.error || ‘שגיאה’, ‘error’); }
};

const toggleActive = async (item) => {
try { await api.put(`/admin/shop/${item.id}`, { active: !item.active }); loadShop(); }
catch {}
};

